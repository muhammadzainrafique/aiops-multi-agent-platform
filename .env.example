# ── LLM Backend ──────────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Kubernetes ───────────────────────────────────────────────────────────────
KUBECONFIG=/root/.kube/config

# ── Agent Settings ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALERT_WEBHOOK_PORT=5001
SUPERVISOR_POLL_INTERVAL=15
